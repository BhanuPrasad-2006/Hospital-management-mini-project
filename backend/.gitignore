# ─── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
package-lock.json

# ─── Environment Variables (NEVER commit secrets) ─────────────────────────────
.env
.env.*
!.env.example

# ─── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── Prisma ────────────────────────────────────────────────────────────────────
prisma/migrations/**/migration_lock.toml

# ─── Build Output ─────────────────────────────────────────────────────────────
dist/
build/

# ─── Uploads (user-uploaded files should not be in git) ────────────────────────
uploads/
temp/
tmp/

# ─── Security / Secrets ───────────────────────────────────────────────────────
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
*.jks

# ─── OS Files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ─── Testing / Coverage ───────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ─── Debug ─────────────────────────────────────────────────────────────────────
.node_repl_history
.eslintcache
