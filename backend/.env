# ============================================
# AROGYASEVA HMS - Environment Variables
# backend/.env
# NEVER commit this file to GitHub!
# Add .env to your .gitignore
# ============================================

# ── Server ────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL Database ───────────────────
# Local development:
DATABASE_URL="postgresql://bhanu:bhanu@2006@localhost:5432/arogyaseva_hms"

# Production (Supabase):
# DATABASE_URL="postgresql://postgres:YourPassword@db.xxxx.supabase.co:5432/postgres"

# ── Redis ─────────────────────────────────
REDIS_URL="redis://localhost:6379"
# Production (Upstash):
# REDIS_URL="rediss://default:password@xxx.upstash.io:6379"

# ── Security ──────────────────────────────
# MUST be exactly 32 characters
ENCRYPTION_KEY="ArogyaSeva-32CharKey-ChangeThis!"

# JWT Secrets (use long random strings)
JWT_SECRET="arogyaseva-jwt-secret-change-this-in-production-min-64-chars"
JWT_REFRESH_SECRET="arogyaseva-refresh-secret-change-this-in-production-min-64"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Bcrypt
BCRYPT_ROUNDS=12

# ── AI APIs ───────────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key-here"
GOOGLE_VISION_API_KEY="AIza-your-key-here"

# ── Google Maps ───────────────────────────
GOOGLE_MAPS_API_KEY="AIza-your-key-here"
GOOGLE_SPEECH_API_KEY="AIza-your-key-here"
GOOGLE_TRANSLATE_API_KEY="AIza-your-key-here"

# ── Firebase ──────────────────────────────
FIREBASE_SERVER_KEY="AAAA-your-key-here"
FIREBASE_PROJECT_ID="arogyaseva-hms"

# ── Twilio WhatsApp ───────────────────────
TWILIO_ACCOUNT_SID="ACxxx"
TWILIO_AUTH_TOKEN="your-token"
TWILIO_WHATSAPP_NUMBER="+14155238886"

# ── AWS S3 ────────────────────────────────
AWS_ACCESS_KEY_ID="AKIAxxx"
AWS_SECRET_ACCESS_KEY="your-secret"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="arogyaseva-storage"
AWS_BACKUP_BUCKET="arogyaseva-backups"

# ── Cloudinary (alternative to S3) ───────
CLOUDINARY_CLOUD_NAME="your-cloud"
CLOUDINARY_API_KEY="your-key"
CLOUDINARY_API_SECRET="your-secret"

# ── Government ABHA API ───────────────────
ABHA_CLIENT_ID="your-id"
ABHA_CLIENT_SECRET="your-secret"
ABHA_BASE_URL="https://sandbox.abdm.gov.in"

# ── Frontend URL (for CORS) ───────────────
FRONTEND_URL="http://localhost:5500"
# Production:
# FRONTEND_URL="https://arogyaseva.vercel.app"
